<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical"
	android:id="@+id/_main">
	<LinearLayout
		android:id="@+id/linear2"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:background="#0E0E0E"
		android:orientation="vertical">
		<LinearLayout
			android:id="@+id/linear3"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="8dp"
			android:gravity="center_vertical"
			android:orientation="horizontal">
			<ImageView
				android:id="@+id/imageview1"
				android:layout_width="40dp"
				android:layout_height="40dp"
				android:src="@drawable/icon_arrow_back_ios_round"
				android:scaleType="fitXY" />
			<TextView
				android:id="@+id/textview1"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginLeft="8dp"
				android:text="ADB HYPERS MANAGER"
				android:textSize="20sp"
				android:textStyle="bold"
				android:layout_weight="1" />
			<ImageView
				android:id="@+id/imageview11"
				android:layout_width="35dp"
				android:layout_height="35dp"
				android:layout_marginRight="8dp"
				android:src="@drawable/icon_power_settings_new_round"
				android:scaleType="fitXY" />
		</LinearLayout>
		<LinearLayout
			android:id="@+id/linear4"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:orientation="vertical">
			<ScrollView
				android:id="@+id/vscroll1"
				android:layout_width="match_parent"
				android:layout_height="match_parent">
				<LinearLayout
					android:id="@+id/linear6"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:background="#0E0E0E"
					android:orientation="vertical">
					<LinearLayout
						android:id="@+id/linear11"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_margin="8dp"
						android:padding="8dp"
						android:background="#1A1A1A"
						android:orientation="horizontal">
						<LinearLayout
							android:id="@+id/linear12"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:gravity="center_vertical"
							android:orientation="horizontal">
							<LinearLayout
								android:id="@+id/linear13"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:layout_margin="5dp"
								android:padding="8dp"
								android:background="#00ACC1"
								android:orientation="horizontal">
								<ImageView
									android:id="@+id/imageview5"
									android:layout_width="30dp"
									android:layout_height="30dp"
									android:src="@drawable/icon_security_round"
									android:scaleType="fitXY" />
							</LinearLayout>
							<LinearLayout
								android:id="@+id/linear14"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:padding="8dp"
								android:orientation="vertical">
								<TextView
									android:id="@+id/textview6"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:layout_marginLeft="5dp"
									android:text="Not Running!!"
									android:textSize="18sp"
									android:textStyle="bold" />
								<TextView
									android:id="@+id/pidrun"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:layout_marginLeft="5dp"
									android:text="TextView"
									android:textSize="12sp"
									android:textColor="#757575" />
							</LinearLayout>
						</LinearLayout>
					</LinearLayout>
					<LinearLayout
						android:id="@+id/linear5"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_margin="8dp"
						android:padding="8dp"
						android:background="#1A1A1A"
						android:orientation="vertical">
						<LinearLayout
							android:id="@+id/linear8"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:gravity="center_vertical"
							android:orientation="horizontal">
							<LinearLayout
								android:id="@+id/linear7"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:layout_margin="5dp"
								android:padding="8dp"
								android:background="#00ACC1"
								android:orientation="horizontal">
								<ImageView
									android:id="@+id/imageview2"
									android:layout_width="30dp"
									android:layout_height="30dp"
									android:src="@drawable/icon_wifi_round"
									android:scaleType="fitXY" />
							</LinearLayout>
							<TextView
								android:id="@+id/textview3"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:layout_marginLeft="5dp"
								android:text="Start Via Wireless Debugging"
								android:textSize="18sp"
								android:textStyle="bold" />
						</LinearLayout>
						<TextView
							android:id="@+id/textview2"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:layout_marginLeft="5dp"
							android:layout_marginTop="20dp"
							android:layout_marginRight="5dp"
							android:layout_marginBottom="10dp"
							android:text="On Android 11 or above, you can enable Wireless debugging and start Hypers directly from your device, without connecting to a computer."
							android:textSize="12sp" />
						<LinearLayout
							android:id="@+id/linear9"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:layout_margin="5dp"
							android:padding="8dp"
							android:background="#00ACC1"
							android:gravity="center_vertical"
							android:orientation="horizontal">
							<ImageView
								android:id="@+id/imageview3"
								android:layout_width="20dp"
								android:layout_height="20dp"
								android:src="@drawable/icon_insert_link_round"
								android:scaleType="fitXY" />
							<TextView
								android:id="@+id/textview4"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:layout_marginLeft="8dp"
								android:layout_marginRight="5dp"
								android:text="Pairing"
								android:textSize="14sp"
								android:textStyle="bold"
								android:textColor="#E0E0E0" />
						</LinearLayout>
						<LinearLayout
							android:id="@+id/linear10"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:layout_margin="5dp"
							android:padding="8dp"
							android:background="#00ACC1"
							android:gravity="center_vertical"
							android:orientation="horizontal">
							<ImageView
								android:id="@+id/imageview4"
								android:layout_width="20dp"
								android:layout_height="20dp"
								android:src="@drawable/icon_play_arrow"
								android:scaleType="fitXY" />
							<TextView
								android:id="@+id/textview5"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:layout_marginLeft="8dp"
								android:layout_marginRight="5dp"
								android:text="Start"
								android:textSize="14sp"
								android:textStyle="bold"
								android:textColor="#E0E0E0" />
						</LinearLayout>
						<LinearLayout
							android:id="@+id/linear26"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:layout_margin="5dp"
							android:padding="8dp"
							android:background="#00ACC1"
							android:gravity="center_vertical"
							android:orientation="horizontal">
							<ImageView
								android:id="@+id/imageview12"
								android:layout_width="20dp"
								android:layout_height="20dp"
								android:src="@drawable/icon_play_arrow"
								android:scaleType="fitXY" />
							<TextView
								android:id="@+id/textview16"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:layout_marginLeft="8dp"
								android:layout_marginRight="5dp"
								android:text="Start Via TCP"
								android:textSize="14sp"
								android:textStyle="bold"
								android:textColor="#E0E0E0" />
						</LinearLayout>
						<LinearLayout
							android:id="@+id/linear27"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:layout_margin="5dp"
							android:padding="8dp"
							android:background="#00ACC1"
							android:gravity="center_vertical"
							android:orientation="horizontal">
							<ImageView
								android:id="@+id/imageview13"
								android:layout_width="20dp"
								android:layout_height="20dp"
								android:src="@drawable/icon_stop_round"
								android:scaleType="fitXY" />
							<TextView
								android:id="@+id/textview17"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:layout_marginLeft="8dp"
								android:layout_marginRight="5dp"
								android:text="Stop TCP"
								android:textSize="14sp"
								android:textStyle="bold"
								android:textColor="#E0E0E0" />
						</LinearLayout>
					</LinearLayout>
					<LinearLayout
						android:id="@+id/linear15"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_margin="8dp"
						android:padding="8dp"
						android:background="#1A1A1A"
						android:orientation="vertical">
						<LinearLayout
							android:id="@+id/linear16"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:gravity="center_vertical"
							android:orientation="horizontal">
							<LinearLayout
								android:id="@+id/linear19"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:layout_margin="5dp"
								android:padding="8dp"
								android:background="#00ACC1"
								android:orientation="horizontal">
								<ImageView
									android:id="@+id/imageview6"
									android:layout_width="30dp"
									android:layout_height="30dp"
									android:src="@drawable/icon_adb_round"
									android:scaleType="fitXY" />
							</LinearLayout>
							<TextView
								android:id="@+id/textview8"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:layout_marginLeft="5dp"
								android:text="Start Via ( ROOTED )"
								android:textSize="18sp"
								android:textStyle="bold" />
						</LinearLayout>
						<TextView
							android:id="@+id/textview7"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:layout_marginLeft="5dp"
							android:layout_marginTop="20dp"
							android:layout_marginRight="5dp"
							android:text="Additionally, HypersManager can start automatically at boot time. If not, please check if the system or third-party tools are restricting HypersManager."
							android:textSize="12sp" />
						<LinearLayout
							android:id="@+id/linear20"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:layout_marginBottom="8dp"
							android:gravity="center_vertical"
							android:orientation="horizontal">
							<TextView
								android:id="@+id/textview11"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:layout_marginLeft="5dp"
								android:layout_marginTop="10dp"
								android:layout_marginBottom="10dp"
								android:text="You can refer to "
								android:textSize="12sp" />
							<TextView
								android:id="@+id/textview12"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:text="Don't kill my app!!"
								android:textSize="12sp"
								android:textStyle="bold"
								android:textColor="#43A047" />
						</LinearLayout>
						<LinearLayout
							android:id="@+id/linear18"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:layout_margin="5dp"
							android:padding="8dp"
							android:background="#00ACC1"
							android:gravity="center_vertical"
							android:orientation="horizontal">
							<ImageView
								android:id="@+id/imageview8"
								android:layout_width="20dp"
								android:layout_height="20dp"
								android:src="@drawable/icon_play_arrow"
								android:scaleType="fitXY" />
							<TextView
								android:id="@+id/textview10"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:layout_marginLeft="8dp"
								android:layout_marginRight="5dp"
								android:text="Start"
								android:textSize="14sp"
								android:textStyle="bold"
								android:textColor="#E0E0E0" />
						</LinearLayout>
					</LinearLayout>
					<LinearLayout
						android:id="@+id/linear21"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_margin="8dp"
						android:padding="8dp"
						android:background="#1A1A1A"
						android:orientation="vertical">
						<LinearLayout
							android:id="@+id/linear22"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:gravity="center_vertical"
							android:orientation="horizontal">
							<LinearLayout
								android:id="@+id/linear25"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:layout_margin="5dp"
								android:padding="8dp"
								android:background="#00ACC1"
								android:orientation="horizontal">
								<ImageView
									android:id="@+id/imageview9"
									android:layout_width="30dp"
									android:layout_height="30dp"
									android:src="@drawable/icon_desktop_windows_round"
									android:scaleType="fitXY" />
							</LinearLayout>
							<TextView
								android:id="@+id/textview14"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:layout_marginLeft="5dp"
								android:text="Start By Connecting To Computer!"
								android:textSize="18sp"
								android:textStyle="bold" />
						</LinearLayout>
						<TextView
							android:id="@+id/textview13"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:layout_marginLeft="5dp"
							android:layout_marginTop="20dp"
							android:layout_marginRight="5dp"
							android:layout_marginBottom="10dp"
							android:text="For non-rooted devices, you'll need to use adb to start HypersManager (requires a computer connection). This process will need to be repeated every time the device restarts."
							android:textSize="12sp" />
						<LinearLayout
							android:id="@+id/linear24"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:layout_margin="5dp"
							android:padding="8dp"
							android:background="#00ACC1"
							android:gravity="center_vertical"
							android:orientation="horizontal">
							<ImageView
								android:id="@+id/imageview10"
								android:layout_width="20dp"
								android:layout_height="20dp"
								android:src="@drawable/icon_code_round_adb"
								android:scaleType="fitXY" />
							<TextView
								android:id="@+id/textview15"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:layout_marginLeft="8dp"
								android:layout_marginRight="5dp"
								android:text="Views Command"
								android:textSize="14sp"
								android:textStyle="bold"
								android:textColor="#E0E0E0" />
						</LinearLayout>
					</LinearLayout>
				</LinearLayout>
			</ScrollView>
		</LinearLayout>
	</LinearLayout>
</LinearLayout>
